<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>NoteFlow</title>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600&family=Google+Sans+Display:wght@400;500;700&family=Roboto+Flex:opsz,wght@8..144,300;8..144,400;8..144,500&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════
   THEMES
════════════════════════════════════════ */
:root {
  --p:#006A6A;--op:#fff;--pc:#9DF0EF;--opc:#002020;
  --sc:#CCE8E8;--s1:#EAF4F4;--s2:#DFF0F0;--s3:#D3ECEC;
  --os:#161D1D;--osv:#3F4949;--out:#6F7979;--outv:#BEC9C9;
  --err:#BA1A1A;--errc:#FFDAD6;--bg:#F4FBFB;--scrim:rgba(0,0,0,.38);
  --r8:8px;--r12:12px;--r16:16px;--r20:20px;--r24:24px;--rf:100px;
  --sh1:0 1px 3px rgba(0,0,0,.07);--sh2:0 3px 10px rgba(0,0,0,.1);--sh3:0 8px 24px rgba(0,0,0,.15);
  --ease:cubic-bezier(.2,0,0,1);
  --fd:'Google Sans Display',sans-serif;--fb:'Google Sans',sans-serif;--ff:'Roboto Flex',sans-serif;
}
[data-t="violet"]{--p:#6750A4;--op:#fff;--pc:#EADDFF;--opc:#21005D;--sc:#E8DEF8;--s1:#F7F2FA;--s2:#F0EBF5;--s3:#E8E3F0;--os:#1C1B1F;--osv:#49454F;--out:#79747E;--outv:#CAC4D0;--bg:#FFFBFE;}
[data-t="rose"]{--p:#9B1B30;--op:#fff;--pc:#FFDAD8;--opc:#3B0009;--sc:#FFD8DC;--s1:#FFF0F1;--s2:#FFE5E7;--s3:#FFDADC;--os:#1C0002;--osv:#534042;--out:#857373;--outv:#D8C2C2;--bg:#FFFBFF;}
[data-t="ocean"]{--p:#0055A5;--op:#fff;--pc:#D4E4FF;--opc:#001B3D;--sc:#C8DFFF;--s1:#EEF4FF;--s2:#E4EFFF;--s3:#D9E9FF;--os:#001B3D;--osv:#324860;--out:#536070;--outv:#ADBDCC;--bg:#F5F9FF;}
[data-t="forest"]{--p:#2D6A4F;--op:#fff;--pc:#B7E4C7;--opc:#0A2E1A;--sc:#CCEBD8;--s1:#EAF5EF;--s2:#DCEEE4;--s3:#CEE7DA;--os:#0A2E1A;--osv:#2D4A38;--out:#4A7060;--outv:#A3C4B0;--bg:#F4FAF6;}
[data-t="sunset"]{--p:#BF5700;--op:#fff;--pc:#FFDBCC;--opc:#3B1500;--sc:#FFD5C2;--s1:#FFF4EE;--s2:#FFEADF;--s3:#FFE0D0;--os:#3B1500;--osv:#6B3520;--out:#8C5030;--outv:#D4B0A0;--bg:#FFFAF8;}
[data-t="midnight"]{--p:#93CAED;--op:#001828;--pc:#1A3A52;--opc:#93CAED;--sc:#1E3A50;--s1:#0D1F2D;--s2:#122537;--s3:#162C40;--os:#DCF0FF;--osv:#A8C8E0;--out:#6A90A8;--outv:#1E3A50;--bg:#080F18;}
[data-t="dark"]{--p:#9DF0EF;--op:#003737;--pc:#004F4F;--opc:#9DF0EF;--sc:#324B4B;--s1:#141D1D;--s2:#1A2525;--s3:#1F2D2D;--os:#E1E9E9;--osv:#BEC9C9;--out:#899393;--outv:#3F4949;--bg:#0E1414;}
[data-t="dark-violet"]{--p:#D0BCFF;--op:#381E72;--pc:#4F378B;--opc:#EADDFF;--sc:#4A4458;--s1:#211F26;--s2:#282530;--s3:#302D38;--os:#E6E1E5;--osv:#CAC4D0;--out:#938F99;--outv:#49454F;--bg:#1C1B1F;}
[data-t="dark-rose"]{--p:#FFB3B4;--op:#680016;--pc:#930025;--opc:#FFDAD8;--sc:#5C3737;--s1:#231718;--s2:#2A1D1E;--s3:#322323;--os:#F5DDDD;--osv:#D8C2C2;--out:#A48C8C;--outv:#534042;--bg:#1C0002;}

/* ════════════════════════════════════════
   RESET — KUNCI FIX MENTOK
════════════════════════════════════════ */
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}

/* FIX UTAMA: html & body full, overflow hidden */
html{
  width:100%;height:100%;
  overflow:hidden;
  /* Paksa warna background di luar app */
  background:#000;
}
body{
  width:100%;height:100%;
  overflow:hidden;
  display:flex;
  align-items:stretch;
  /* Center di desktop, full di mobile */
  justify-content:center;
  background:#000;
  /* Pastikan font smoothing */
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}

/* ROOT — container utama app */
#R{
  /* Full lebar SELALU — ini yg fix mentok */
  width:100%;
  /* Batasi hanya di layar lebar (PC/tablet) */
  max-width:460px;
  height:100%;
  position:relative;
  overflow:hidden;
  background:var(--bg);
  display:flex;
  flex-direction:column;
  font-family:var(--fb);
  color:var(--os);
  transition:background .25s;
  /* Pisahkan dari edge di HP via padding safe area */
  padding-left:env(safe-area-inset-left);
  padding-right:env(safe-area-inset-right);
}

/* ════════════════════════════════════════
   VIEWS
════════════════════════════════════════ */
.vw{
  position:absolute;
  /* Inset 0 = isi parent penuh, tidak mentok */
  top:0;left:0;right:0;bottom:0;
  display:flex;flex-direction:column;
  background:var(--bg);
  transition:transform .3s var(--ease),opacity .25s;
  will-change:transform;
  overflow:hidden;
}
.vw.gone{display:none}
.vw.sleft{transform:translateX(-100%);opacity:0;pointer-events:none}
.vw.sright{transform:translateX(100%)}

/* ════════════════════════════════════════
   ICON BUTTON
════════════════════════════════════════ */
.ib{
  width:38px;height:38px;border-radius:var(--rf);
  border:none;background:transparent;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--osv);
  transition:background .15s;
  position:relative;overflow:hidden;flex-shrink:0;
}
.ib:active{background:color-mix(in srgb,var(--os) 14%,transparent)}
.ib.act{color:var(--p);background:color-mix(in srgb,var(--p) 14%,transparent)}

/* ════════════════════════════════════════
   TOP BAR
════════════════════════════════════════ */
.tbar{
  /* Padding kiri/kanan 12px — tidak 0 */
  padding:12px 12px 8px;
  background:var(--bg);flex-shrink:0;
  border-bottom:1px solid transparent;
  transition:border-color .2s,background .25s;
}
.tbar.sc{border-color:var(--outv)}
.tbr{display:flex;align-items:center;gap:2px;margin-bottom:10px}
.tbar-title{
  font-family:var(--fd);font-size:24px;font-weight:500;
  color:var(--os);flex:1;letter-spacing:-.3px;
  /* Jangan overflow ke luar */
  overflow:hidden;white-space:nowrap;text-overflow:ellipsis;
  padding-left:2px;
}

/* ════════════════════════════════════════
   SEARCH
════════════════════════════════════════ */
.srch{
  display:flex;align-items:center;gap:8px;
  background:var(--s2);border-radius:var(--rf);
  padding:9px 14px;transition:all .2s;
  /* Tidak boleh overflow */
  width:100%;
}
.srch:focus-within{background:var(--s3);outline:2px solid var(--p)}
.srch input{
  flex:1;border:none;background:transparent;
  font-family:var(--fb);font-size:15px;color:var(--os);
  outline:none;
  /* min-width 0 penting untuk flex item */
  min-width:0;
}
.srch input::placeholder{color:var(--osv)}

/* ════════════════════════════════════════
   CHIPS
════════════════════════════════════════ */
.chips{
  display:flex;gap:7px;
  /* Padding kiri/kanan sama dengan tbar */
  padding:8px 12px 4px;
  overflow-x:auto;scrollbar-width:none;flex-shrink:0;
  /* Clip overflow */
  -webkit-overflow-scrolling:touch;
}
.chips::-webkit-scrollbar{display:none}
.chip{
  display:flex;align-items:center;gap:4px;
  padding:6px 13px;border-radius:var(--rf);
  border:1.5px solid var(--outv);background:transparent;
  font-family:var(--fb);font-size:12px;color:var(--osv);
  cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0;
}
.chip.act{background:var(--sc);border-color:transparent;color:var(--os);font-weight:500}
.chip:active{transform:scale(.95)}

/* ════════════════════════════════════════
   CONTENT
════════════════════════════════════════ */
.cont{
  flex:1;overflow-y:auto;overflow-x:hidden;
  /* Padding kiri/kanan 10px, bawah buat FAB */
  padding:8px 10px 80px;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior-y:contain;
}
.cont::-webkit-scrollbar{width:3px}
.cont::-webkit-scrollbar-thumb{background:var(--outv);border-radius:2px}

/* ════════════════════════════════════════
   GRID
════════════════════════════════════════ */
.grid{
  display:grid;
  grid-template-columns:repeat(var(--cols,2),1fr);
  gap:8px;
  /* Penting: width 100% dari parent */
  width:100%;
}
.slbl{font-size:11px;font-weight:600;color:var(--osv);letter-spacing:.8px;text-transform:uppercase;padding:6px 2px 3px;grid-column:1/-1}

/* ════════════════════════════════════════
   NOTE CARD
════════════════════════════════════════ */
.nc{
  background:var(--s1);border-radius:var(--r20);
  padding:13px;cursor:pointer;
  border:1.5px solid transparent;
  position:relative;overflow:hidden;
  animation:ci .28s var(--ease) both;
  contain:layout style;
  /* Pastikan tidak overflow container */
  min-width:0;word-break:break-word;
}
@keyframes ci{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.nc:active{opacity:.8;transform:scale(.97)}

/* Card colors light */
.nc.cy{background:#FFF9C4}.nc.cp{background:#FCE4EC}.nc.cb{background:#E3F2FD}
.nc.cg{background:#E8F5E9}.nc.cv{background:#F3E5F5}.nc.co{background:#FFF3E0}.nc.cm{background:#E8EAF6}
/* Card colors dark */
[data-t="dark"] .nc.cy,[data-t="dark-violet"] .nc.cy,[data-t="midnight"] .nc.cy{background:#3D3500}
[data-t="dark"] .nc.cp,[data-t="dark-violet"] .nc.cp,[data-t="midnight"] .nc.cp,[data-t="dark-rose"] .nc.cp{background:#3D0017}
[data-t="dark"] .nc.cb,[data-t="dark-violet"] .nc.cb,[data-t="midnight"] .nc.cb,[data-t="dark-rose"] .nc.cb{background:#001D36}
[data-t="dark"] .nc.cg,[data-t="dark-violet"] .nc.cg,[data-t="midnight"] .nc.cg,[data-t="dark-rose"] .nc.cg{background:#002105}
[data-t="dark"] .nc.cv,[data-t="dark-violet"] .nc.cv,[data-t="midnight"] .nc.cv,[data-t="dark-rose"] .nc.cv{background:#2A0041}
[data-t="dark"] .nc.co,[data-t="dark-violet"] .nc.co,[data-t="midnight"] .nc.co,[data-t="dark-rose"] .nc.co{background:#331200}
[data-t="dark"] .nc.cm,[data-t="dark-violet"] .nc.cm,[data-t="midnight"] .nc.cm,[data-t="dark-rose"] .nc.cm{background:#0D0F3A}

.nc-title{font-size:13px;font-weight:600;color:var(--os);margin-bottom:5px;line-height:1.35;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.nc-body{font-size:12px;color:var(--osv);line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical}
.nc-body *{display:inline!important;font-size:inherit!important}
.nc-badges{display:flex;gap:3px;align-items:center;flex-wrap:wrap;margin-top:6px}
.btag{padding:2px 7px;border-radius:var(--rf);background:color-mix(in srgb,var(--sc) 80%,transparent);font-size:10px;color:var(--p);font-weight:500}
.nc-date{font-size:10px;color:var(--osv);margin-top:6px;font-family:var(--ff)}

/* ════════════════════════════════════════
   TODO CARD
════════════════════════════════════════ */
.tc{background:var(--s1);border-radius:var(--r20);padding:13px;cursor:pointer;animation:ci .28s var(--ease) both;contain:layout style;min-width:0}
.tc:active{opacity:.8;transform:scale(.97)}
.tc-hd{display:flex;align-items:center;gap:6px;margin-bottom:7px;min-width:0}
.tc-ttl{font-size:13px;font-weight:600;color:var(--os);flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;min-width:0}
.tc-pct{font-size:11px;color:var(--p);font-weight:600;flex-shrink:0}
.tc-prog{height:3px;background:var(--outv);border-radius:2px;margin-bottom:8px;overflow:hidden}
.tc-bar{height:100%;background:var(--p);border-radius:2px;transition:width .3s var(--ease)}
.ti{display:flex;align-items:center;gap:7px;padding:4px 0;border-bottom:1px solid var(--outv)}
.ti:last-child{border:none}
.ti-cb{width:17px;height:17px;border-radius:50%;border:2px solid var(--p);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.ti-cb.done{background:var(--p);border-color:var(--p)}
.ti-cb.done::after{content:'✓';color:var(--op);font-size:9px;font-weight:700}
.ti-txt{flex:1;font-size:12px;color:var(--os);line-height:1.4;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;min-width:0}
.ti-txt.done{text-decoration:line-through;color:var(--osv)}

/* ════════════════════════════════════════
   EMPTY
════════════════════════════════════════ */
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:56px 24px;grid-column:1/-1;gap:10px}
.empty-ic{font-size:48px;opacity:.2}
.empty-tx{font-size:14px;color:var(--osv);text-align:center;line-height:1.6}

/* ════════════════════════════════════════
   FAB
════════════════════════════════════════ */
.fab-wrap{
  position:absolute;
  /* Jarak dari kanan 14px, dari bottom nav */
  bottom:68px;right:14px;
  display:flex;flex-direction:column;align-items:flex-end;gap:8px;z-index:20;
}
.fab{width:52px;height:52px;border-radius:var(--rf);border:none;background:var(--pc);cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:var(--sh3);color:var(--opc);transition:transform .18s}
.fab:active{transform:scale(.88)}
.fab-ext{display:flex;align-items:center;gap:9px;background:var(--s2);border-radius:var(--rf);padding:9px 15px;box-shadow:var(--sh2);cursor:pointer;border:none;font-family:var(--fb);font-size:13px;font-weight:500;color:var(--os);white-space:nowrap;opacity:0;transform:translateY(8px) scale(.95);pointer-events:none;transition:opacity .18s,transform .18s}
.fab-ext.vis{opacity:1;transform:none;pointer-events:all}
.fab-ext-ic{width:28px;height:28px;border-radius:50%;background:var(--pc);display:flex;align-items:center;justify-content:center;color:var(--opc);flex-shrink:0;font-size:14px}

/* ════════════════════════════════════════
   BOTTOM NAV
════════════════════════════════════════ */
.bnav{
  display:flex;background:var(--s1);
  border-top:1px solid var(--outv);
  /* Safe area bottom */
  padding:5px 0 max(5px,env(safe-area-inset-bottom));
  flex-shrink:0;z-index:15;
  /* Tidak overflow */
  width:100%;
}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:3px 0;cursor:pointer;border:none;background:transparent;color:var(--osv);transition:color .18s;min-width:0}
.ni.act{color:var(--p)}
.ni-ind{width:48px;height:26px;border-radius:var(--rf);background:transparent;display:flex;align-items:center;justify-content:center;transition:background .18s;font-size:17px}
.ni.act .ni-ind{background:var(--sc)}
.ni-lbl{font-size:10px;font-weight:500;white-space:nowrap}

/* TRASH BAR */
.trash-bar{display:none;align-items:center;justify-content:space-between;padding:7px 14px;border-bottom:1px solid var(--outv);flex-shrink:0}
.trash-bar.show{display:flex}
.t-info{font-size:12px;color:var(--osv)}
.btn-danger{padding:6px 13px;border-radius:var(--rf);border:none;background:var(--errc);color:var(--err);font-family:var(--fb);font-size:12px;font-weight:600;cursor:pointer}
.btn-danger:active{transform:scale(.95)}

/* ════════════════════════════════════════
   EDITOR VIEW
════════════════════════════════════════ */
.ed-tbar{display:flex;align-items:center;gap:2px;padding:10px 8px 8px;border-bottom:1px solid var(--outv);flex-shrink:0;background:var(--bg);width:100%}
.ed-acts{display:flex;align-items:center;gap:2px;margin-left:auto;flex-wrap:nowrap;overflow:hidden}
.ed-title{width:100%;border:none;background:transparent;outline:none;font-family:var(--fd);font-size:20px;font-weight:500;color:var(--os);padding:10px 14px 6px;resize:none;overflow:hidden;line-height:1.3}
.ed-title::placeholder{color:var(--out)}
.ed-meta{display:flex;align-items:center;gap:6px;padding:6px 14px;border-bottom:1px solid var(--outv);overflow-x:auto;scrollbar-width:none;flex-shrink:0;width:100%}
.ed-meta::-webkit-scrollbar{display:none}
.mc{display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:var(--rf);border:1.5px solid var(--outv);background:transparent;font-family:var(--fb);font-size:12px;color:var(--osv);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0}
.mc.act{background:var(--sc);border-color:transparent;color:var(--os);font-weight:500}
.mc:active{transform:scale(.95)}
.ms{width:1px;height:16px;background:var(--outv);flex-shrink:0}

/* FORMAT BAR */
.fmt{display:flex;align-items:center;gap:1px;padding:3px 8px;border-bottom:1px solid var(--outv);overflow-x:auto;scrollbar-width:none;flex-shrink:0;background:var(--s1);width:100%}
.fmt::-webkit-scrollbar{display:none}
.fb{min-width:28px;height:28px;border-radius:var(--r8);border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--osv);font-size:12px;font-weight:700;transition:background .12s;font-family:var(--fb);flex-shrink:0;padding:0 3px}
.fb:active{background:color-mix(in srgb,var(--os) 14%,transparent);transform:scale(.88)}
.fb.on{background:color-mix(in srgb,var(--p) 16%,transparent);color:var(--p)}
.fsep{width:1px;height:16px;background:var(--outv);margin:0 2px;flex-shrink:0}
.fsel{border:none;background:transparent;font-family:var(--fb);font-size:11px;color:var(--osv);outline:none;cursor:pointer;padding:0 3px;height:28px;flex-shrink:0}

/* RICH BODY */
.ed-body{flex:1;overflow-y:auto;padding:12px 15px 16px;outline:none;font-family:var(--ff);font-size:16px;line-height:1.75;color:var(--os);-webkit-overflow-scrolling:touch;overscroll-behavior:contain;word-break:break-word;min-width:0;width:100%}
.ed-body:empty::before{content:attr(data-ph);color:var(--out);pointer-events:none}
.ed-body h1{font-family:var(--fd);font-size:22px;font-weight:700;margin:10px 0 5px}
.ed-body h2{font-family:var(--fd);font-size:18px;font-weight:600;margin:8px 0 4px}
.ed-body h3{font-size:15px;font-weight:600;margin:6px 0 3px}
.ed-body ul,.ed-body ol{padding-left:20px;margin:5px 0}
.ed-body li{margin:3px 0}
.ed-body blockquote{border-left:3px solid var(--p);padding:8px 13px;margin:7px 0;background:color-mix(in srgb,var(--pc) 20%,transparent);border-radius:0 var(--r8) var(--r8) 0;color:var(--osv);font-style:italic}
.ed-body code{background:var(--s2);border-radius:4px;padding:1px 5px;font-family:monospace;font-size:14px;color:var(--p)}
.ed-body pre{background:var(--s2);border-radius:var(--r12);padding:12px;margin:7px 0;overflow-x:auto}
.ed-body pre code{background:none;padding:0}
.ed-body a{color:var(--p)}
.ed-body mark{background:color-mix(in srgb,#FFEB3B 55%,transparent);border-radius:2px;padding:0 2px}
.ed-body hr{border:none;border-top:2px solid var(--outv);margin:12px 0}
.ed-body table{width:100%;border-collapse:collapse;margin:7px 0;font-size:13px;display:block;overflow-x:auto}
.ed-body th{background:var(--sc);padding:6px 9px;text-align:left;font-weight:600;border:1px solid var(--outv)}
.ed-body td{padding:5px 9px;border:1px solid var(--outv)}
.ed-body tr:nth-child(even) td{background:var(--s1)}

/* ED STATUS */
.ed-status{display:flex;align-items:center;gap:5px;padding:6px 12px max(10px,env(safe-area-inset-bottom));border-top:1px solid var(--outv);flex-shrink:0;background:var(--s1);overflow-x:auto;scrollbar-width:none;width:100%}
.ed-status::-webkit-scrollbar{display:none}
.cdot{width:20px;height:20px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:transform .15s;flex-shrink:0}
.cdot:active{transform:scale(1.25)}
.cdot.sel{border-color:var(--os);transform:scale(1.1)}
.wc{font-size:11px;color:var(--osv);margin-left:auto;white-space:nowrap;flex-shrink:0}

/* FIND BAR */
.find-bar{display:none;align-items:center;gap:5px;padding:5px 10px;border-bottom:1px solid var(--outv);flex-shrink:0;background:var(--s1);width:100%}
.find-bar.show{display:flex}
.find-inp{flex:1;border:none;background:var(--s2);border-radius:var(--r8);padding:6px 10px;font-family:var(--fb);font-size:13px;color:var(--os);outline:none;min-width:0}
.find-inp:focus{outline:2px solid var(--p)}

/* ════════════════════════════════════════
   CHAT AI VIEW
════════════════════════════════════════ */
.chat-tbar{display:flex;align-items:center;gap:4px;padding:10px 8px 8px;border-bottom:1px solid var(--outv);flex-shrink:0;background:var(--bg);width:100%}
.chat-info{flex:1;padding-left:4px;min-width:0}
.chat-name{font-size:15px;font-weight:600;color:var(--os);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.chat-status{font-size:11px;color:var(--p)}
.chat-av{width:34px;height:34px;border-radius:50%;background:var(--pc);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}

.chat-msgs{flex:1;overflow-y:auto;padding:10px 10px 6px;display:flex;flex-direction:column;gap:8px;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;width:100%}
.chat-msgs::-webkit-scrollbar{width:3px}
.chat-msgs::-webkit-scrollbar-thumb{background:var(--outv);border-radius:2px}

.msg{display:flex;gap:7px;align-items:flex-end;animation:ci .2s var(--ease) both;min-width:0;width:100%}
.msg.user{flex-direction:row-reverse}
.msg-av{width:26px;height:26px;border-radius:50%;background:var(--pc);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.msg-av.uav{background:var(--p);color:var(--op);font-size:11px;font-weight:700}
.msg-wrap{display:flex;flex-direction:column;max-width:80%;min-width:0}
.msg.user .msg-wrap{align-items:flex-end}
.msg-bubble{padding:9px 13px;border-radius:17px;font-size:14px;line-height:1.55;word-break:break-word}
.msg.ai .msg-bubble{background:var(--s1);color:var(--os);border-bottom-left-radius:4px}
.msg.user .msg-bubble{background:var(--p);color:var(--op);border-bottom-right-radius:4px}
.msg-time{font-size:10px;color:var(--osv);margin-top:2px;padding:0 2px}

/* TYPING */
.typing{display:flex;align-items:center;gap:4px;padding:10px 14px;background:var(--s1);border-radius:17px;border-bottom-left-radius:4px;width:fit-content}
.typing span{width:6px;height:6px;border-radius:50%;background:var(--osv);animation:bou .9s infinite}
.typing span:nth-child(2){animation-delay:.2s}
.typing span:nth-child(3){animation-delay:.4s}
@keyframes bou{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

/* QUICK PROMPTS */
.qps{display:flex;gap:6px;padding:6px 10px 0;overflow-x:auto;scrollbar-width:none;flex-shrink:0;width:100%}
.qps::-webkit-scrollbar{display:none}
.qp{padding:5px 11px;border-radius:var(--rf);border:1.5px solid var(--p);background:transparent;font-family:var(--fb);font-size:11px;color:var(--p);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0}
.qp:active{background:var(--sc);transform:scale(.95)}

/* SAVE AI AS NOTE */
.ai-save-btn{display:flex;align-items:center;gap:5px;padding:5px 10px;border-radius:var(--r8);background:color-mix(in srgb,var(--p) 10%,transparent);border:1px solid color-mix(in srgb,var(--p) 25%,transparent);cursor:pointer;font-family:var(--fb);font-size:11px;color:var(--p);margin-top:5px;width:fit-content;transition:all .15s}
.ai-save-btn:active{transform:scale(.95)}

/* CHAT INPUT */
.chat-input-wrap{padding:7px 10px max(9px,env(safe-area-inset-bottom));border-top:1px solid var(--outv);display:flex;align-items:flex-end;gap:7px;flex-shrink:0;background:var(--bg);width:100%}
.chat-inp{flex:1;background:var(--s2);border-radius:20px;padding:9px 13px;font-family:var(--fb);font-size:14px;color:var(--os);border:none;outline:none;resize:none;max-height:90px;overflow-y:auto;line-height:1.4;min-width:0}
.chat-inp:focus{outline:2px solid var(--p)}
.chat-inp::placeholder{color:var(--osv)}
.chat-send{width:38px;height:38px;border-radius:50%;border:none;background:var(--p);color:var(--op);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .18s}
.chat-send:active{transform:scale(.88)}
.chat-send:disabled{background:var(--outv)}

/* ════════════════════════════════════════
   FAVORITE VIEW
════════════════════════════════════════ */
.fav-wrap{flex:1;overflow-y:auto;padding:10px 10px 80px;-webkit-overflow-scrolling:touch}
.fav-section{margin-bottom:16px}
.fav-sec-title{font-size:12px;font-weight:600;color:var(--osv);letter-spacing:.8px;text-transform:uppercase;padding:6px 2px 8px}
.fav-item{display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--s1);border-radius:var(--r16);margin-bottom:7px;cursor:pointer;transition:all .15s}
.fav-item:active{transform:scale(.98);opacity:.85}
.fav-item-ico{width:36px;height:36px;border-radius:var(--r12);background:var(--pc);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.fav-item-info{flex:1;min-width:0}
.fav-item-title{font-size:14px;font-weight:500;color:var(--os);overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.fav-item-sub{font-size:11px;color:var(--osv);margin-top:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.fav-item-badge{font-size:11px;padding:2px 8px;border-radius:var(--rf);background:var(--sc);color:var(--p);font-weight:500;flex-shrink:0}

/* ════════════════════════════════════════
   SHEETS / OVERLAYS
════════════════════════════════════════ */
.ov{position:fixed;inset:0;background:var(--scrim);z-index:100;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .22s;backdrop-filter:blur(4px)}
.ov.open{opacity:1;pointer-events:all}
.sheet{
  /* Lebar mengikuti #R */
  width:100%;max-width:460px;
  background:var(--bg);
  border-radius:var(--r24) var(--r24) 0 0;
  display:flex;flex-direction:column;
  transform:translateY(100%);
  transition:transform .3s var(--ease);
  overflow:hidden;
}
.ov.open .sheet{transform:none}
.sh-tall{height:92dvh}
.sh-mid{max-height:80dvh}
.handle{width:28px;height:4px;border-radius:2px;background:var(--outv);margin:10px auto 0;flex-shrink:0}
.sh-hd{display:flex;align-items:center;padding:8px 8px 6px 13px;gap:4px;flex-shrink:0}
.sh-ttl{font-family:var(--fd);font-size:18px;font-weight:500;flex:1;min-width:0;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}

/* TODO SHEET */
.td-items{flex:1;overflow-y:auto;padding:0 13px 6px;-webkit-overflow-scrolling:touch}
.td-item{display:flex;align-items:center;gap:7px;padding:8px 0;border-bottom:1px solid var(--outv)}
.td-item:last-child{border:none}
.td-drag{color:var(--osv);cursor:grab;font-size:15px;user-select:none;flex-shrink:0}
.td-inp{flex:1;border:none;background:transparent;font-family:var(--fb);font-size:13px;color:var(--os);outline:none;min-width:0}
.td-inp::placeholder{color:var(--out)}
.td-del{width:24px;height:24px;border-radius:var(--rf);border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--osv);font-size:13px;flex-shrink:0}
.td-del:active{color:var(--err)}
.td-add-row{display:flex;align-items:center;gap:7px;padding:9px 13px max(11px,env(safe-area-inset-bottom));border-top:1px solid var(--outv);flex-shrink:0}
.td-add-inp{flex:1;border:none;background:var(--s2);border-radius:var(--rf);padding:8px 13px;font-family:var(--fb);font-size:13px;color:var(--os);outline:none;min-width:0}
.td-add-inp:focus{outline:2px solid var(--p)}
.td-add-btn{width:34px;height:34px;border-radius:50%;border:none;background:var(--p);color:var(--op);cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.td-add-btn:active{transform:scale(.88)}

/* THEME GRID */
.th-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:10px 12px max(18px,env(safe-area-inset-bottom));overflow-y:auto}
.th-card{border-radius:var(--r16);padding:12px;cursor:pointer;border:2px solid transparent;transition:all .18s;position:relative}
.th-card:active{transform:scale(.96)}
.th-card.sel{border-color:var(--p)}
.th-card.sel::after{content:'✓';position:absolute;top:8px;right:8px;width:18px;height:18px;border-radius:50%;background:var(--p);color:var(--op);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700}
.sw-row{display:flex;gap:4px;margin-bottom:6px}
.sw{width:17px;height:17px;border-radius:50%}
.th-nm{font-size:12px;font-weight:600}
.th-sb{font-size:10px;color:var(--osv)}

/* STATS */
.st-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:10px 12px max(18px,env(safe-area-inset-bottom));overflow-y:auto}
.st-card{background:var(--s1);border-radius:var(--r16);padding:13px}
.st-num{font-size:26px;font-weight:600;color:var(--p);font-family:var(--fd)}
.st-lbl{font-size:11px;color:var(--osv);margin-top:2px}

/* WIDGET */
.wg-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:10px 12px max(18px,env(safe-area-inset-bottom));overflow-y:auto}
.wg-card{border-radius:var(--r16);background:var(--pc);padding:13px;cursor:pointer;border:2px solid transparent;transition:all .18s;min-width:0}
.wg-card:active{transform:scale(.95)}
.wg-card.sel{border-color:var(--p)}
.wg-card.wide{grid-column:1/-1}
.wg-lbl{font-size:10px;font-weight:600;color:var(--p);letter-spacing:.4px;text-transform:uppercase;margin-bottom:5px}
.wg-nt{font-size:12px;font-weight:600;color:var(--opc);margin-bottom:3px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.wg-nb{font-size:11px;color:color-mix(in srgb,var(--opc) 65%,transparent);overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;line-height:1.4}

/* EXPORT */
.exp-list{overflow-y:auto;padding:4px 0 max(18px,env(safe-area-inset-bottom))}
.exp-item{display:flex;align-items:center;gap:12px;padding:12px 14px;cursor:pointer;transition:background .15s}
.exp-item:active{background:color-mix(in srgb,var(--os) 8%,transparent)}
.exp-ic{width:36px;height:36px;border-radius:var(--r12);background:var(--pc);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.exp-nm{font-size:13px;font-weight:500;color:var(--os)}
.exp-sb{font-size:11px;color:var(--osv);margin-top:1px}

/* DIALOG */
.dlg-ov{position:fixed;inset:0;background:var(--scrim);z-index:150;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;padding:20px}
.dlg-ov.open{opacity:1;pointer-events:all}
.dlg{background:var(--s2);border-radius:var(--r24);padding:22px;width:100%;max-width:300px;transform:scale(.88);transition:transform .2s var(--ease)}
.dlg-ov.open .dlg{transform:none}
.dlg-t{font-size:18px;font-weight:500;margin-bottom:7px}
.dlg-b{font-size:13px;color:var(--osv);margin-bottom:18px;line-height:1.5}
.dlg-a{display:flex;justify-content:flex-end;gap:6px}
.bnt{padding:9px 14px;border-radius:var(--rf);border:none;background:transparent;font-family:var(--fb);font-size:13px;font-weight:500;cursor:pointer;color:var(--p);transition:background .15s}
.bnt:active{background:color-mix(in srgb,var(--p) 10%,transparent)}
.bnt.err{color:var(--err)}
.bnt.err:active{background:color-mix(in srgb,var(--err) 10%,transparent)}

/* SNACK */
.snack{position:fixed;bottom:72px;left:50%;transform:translateX(-50%) translateY(50px);background:var(--os);color:var(--bg);padding:10px 16px;border-radius:var(--r12);font-size:13px;font-family:var(--fb);transition:transform .25s var(--ease),opacity .25s;z-index:200;white-space:nowrap;box-shadow:var(--sh3);opacity:0;pointer-events:none}
.snack.show{transform:translateX(-50%) translateY(0);opacity:1}
</style>
</head>
<body>
<div id="R"><!-- ROOT -->

<!-- ══ VIEW: LIST ══ -->
<div class="vw" id="vL">
  <div class="tbar" id="tbar">
    <div class="tbr">
      <span class="tbar-title" id="pgTitle">Catatan</span>
      <button class="ib" onclick="openStats()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></button>
      <button class="ib" onclick="openTheme()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg></button>
      <button class="ib" onclick="openWidget()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/></svg></button>
      <button class="ib" id="viewBtn" onclick="toggleCols()"><svg id="viewIco" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></button>
      <button class="ib" onclick="openExport()"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg></button>
    </div>
    <div class="srch">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="srchInp" placeholder="Cari catatan..." oninput="doSearch()">
      <button class="ib" id="srchX" style="display:none;width:24px;height:24px" onclick="clearSearch()"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
  </div>
  <div class="chips" id="chips">
    <button class="chip act" onclick="filterTag('all',this)">Semua</button>
    <button class="chip" onclick="filterTag('teknologi',this)">💻 Tech</button>
    <button class="chip" onclick="filterTag('kerja',this)">💼 Kerja</button>
    <button class="chip" onclick="filterTag('ide',this)">💡 Ide</button>
    <button class="chip" onclick="filterTag('personal',this)">👤 Personal</button>
    <button class="chip" onclick="filterTag('todo',this)">☑ To-Do</button>
  </div>
  <div class="trash-bar" id="trashBar">
    <span class="t-info" id="trashInfo">0 item</span>
    <button class="btn-danger" onclick="emptyTrash()">🗑 Kosongkan</button>
  </div>
  <div class="cont" id="cont">
    <div class="grid" id="grid" style="--cols:2"></div>
  </div>
  <div class="fab-wrap" id="fabWrap">
    <div id="fabMenu" style="display:flex;flex-direction:column;align-items:flex-end;gap:8px">
      <button class="fab-ext" id="fabTd" onclick="closeFab();openTdEd()"><div class="fab-ext-ic">☑</div>To-Do</button>
      <button class="fab-ext" id="fabNt" onclick="closeFab();openEditor()"><div class="fab-ext-ic">✏</div>Catatan</button>
    </div>
    <button class="fab" id="mainFab" onclick="toggleFab()">
      <svg id="fabIco" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
    </button>
  </div>
  <nav class="bnav">
    <button class="ni act" onclick="navTo('notes',this)"><div class="ni-ind">📝</div><span class="ni-lbl">Catatan</span></button>
    <button class="ni" onclick="navTo('todo',this)"><div class="ni-ind">☑️</div><span class="ni-lbl">To-Do</span></button>
    <button class="ni" onclick="navTo('fav',this)"><div class="ni-ind">⭐</div><span class="ni-lbl">Favorit</span></button>
    <button class="ni" onclick="showChat()"><div class="ni-ind">🤖</div><span class="ni-lbl">AI</span></button>
    <button class="ni" onclick="navTo('trash',this)"><div class="ni-ind">🗑️</div><span class="ni-lbl">Sampah</span></button>
  </nav>
</div>

<!-- ══ VIEW: EDITOR ══ -->
<div class="vw gone sright" id="vE">
  <div class="ed-tbar">
    <button class="ib" onclick="closeEditor()"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg></button>
    <div class="ed-acts">
      <button class="ib" id="pinBtn" onclick="togglePin()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg></button>
      <button class="ib" id="starBtn" onclick="toggleFav()"><svg id="starIco" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></button>
      <button class="ib" id="lockBtn" onclick="toggleLock()"><svg id="lockIco" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></button>
      <button class="ib" id="findBtn" onclick="toggleFind()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></button>
      <button class="ib" onclick="shareNote()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></button>
      <button class="ib" style="color:var(--err)" onclick="delNote()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6M9 6V4h6v2"/></svg></button>
      <button class="ib" style="color:var(--p);width:auto;padding:0 10px;font-size:13px;font-weight:600;font-family:var(--fb)" onclick="saveNote()">Simpan</button>
    </div>
  </div>
  <div class="find-bar" id="findBar">
    <input class="find-inp" id="findInp" placeholder="Cari..." oninput="doFind()">
    <input class="find-inp" id="replInp" placeholder="Ganti..." style="max-width:110px">
    <span style="font-size:11px;color:var(--osv);white-space:nowrap;flex-shrink:0" id="findInfo">0</span>
    <button class="ib" style="width:26px;height:26px" onclick="doReplace()"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg></button>
    <button class="ib" style="width:26px;height:26px;color:var(--err)" onclick="toggleFind()"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
  </div>
  <textarea class="ed-title" id="edTitle" placeholder="Judul..." rows="1" oninput="autoRes(this)"></textarea>
  <div class="ed-meta" id="edMeta"></div>
  <div class="fmt">
    <select class="fsel" onchange="xCmd('formatBlock',this.value);this.value='p'"><option value="p">Teks</option><option value="h1">H1</option><option value="h2">H2</option><option value="h3">H3</option></select>
    <div class="fsep"></div>
    <button class="fb" id="fB" onclick="xCmd('bold')"><b>B</b></button>
    <button class="fb" id="fI" onclick="xCmd('italic')"><i>I</i></button>
    <button class="fb" id="fU" onclick="xCmd('underline')" style="text-decoration:underline">U</button>
    <button class="fb" id="fS" onclick="xCmd('strikeThrough')" style="text-decoration:line-through">S</button>
    <button class="fb" onclick="xCmd('hiliteColor','#FFEB3B')">🖊</button>
    <div class="fsep"></div>
    <button class="fb" onclick="xCmd('insertUnorderedList')">•</button>
    <button class="fb" onclick="xCmd('insertOrderedList')">1.</button>
    <button class="fb" onclick="xCmd('formatBlock','blockquote')">"</button>
    <button class="fb" onclick="insCode()">&lt;/&gt;</button>
    <div class="fsep"></div>
    <button class="fb" onclick="xCmd('justifyLeft')">⬅</button>
    <button class="fb" onclick="xCmd('justifyCenter')">↔</button>
    <button class="fb" onclick="xCmd('justifyRight')">➡</button>
    <div class="fsep"></div>
    <button class="fb" onclick="insLink()">🔗</button>
    <button class="fb" onclick="insTable()">⊞</button>
    <button class="fb" onclick="xCmd('insertHTML','<hr>')">—</button>
    <div class="fsep"></div>
    <button class="fb" onclick="xCmd('undo')">↩</button>
    <button class="fb" onclick="xCmd('redo')">↪</button>
  </div>
  <div class="ed-body" id="edBody" contenteditable="true" data-ph="Mulai menulis..." onkeyup="updateWC();updFmt()" onmouseup="updFmt()" ontouchend="updFmt()"></div>
  <div class="ed-status">
    <span style="font-size:11px;color:var(--osv);flex-shrink:0">Warna:</span>
    <div class="cdot sel" style="background:var(--bg);border:1.5px solid var(--outv)" data-c="" onclick="setColor(this,'')"></div>
    <div class="cdot" style="background:#FFF9C4" data-c="cy" onclick="setColor(this,'cy')"></div>
    <div class="cdot" style="background:#FCE4EC" data-c="cp" onclick="setColor(this,'cp')"></div>
    <div class="cdot" style="background:#E3F2FD" data-c="cb" onclick="setColor(this,'cb')"></div>
    <div class="cdot" style="background:#E8F5E9" data-c="cg" onclick="setColor(this,'cg')"></div>
    <div class="cdot" style="background:#F3E5F5" data-c="cv" onclick="setColor(this,'cv')"></div>
    <div class="cdot" style="background:#FFF3E0" data-c="co" onclick="setColor(this,'co')"></div>
    <div class="cdot" style="background:#E8EAF6" data-c="cm" onclick="setColor(this,'cm')"></div>
    <span class="wc" id="edWC">0 kata</span>
  </div>
</div>

<!-- ══ VIEW: CHAT AI ══ -->
<div class="vw gone sright" id="vC">
  <div class="chat-tbar">
    <button class="ib" onclick="closeChat()"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg></button>
    <div class="chat-av">🤖</div>
    <div class="chat-info">
      <div class="chat-name">NoteFlow AI</div>
      <div class="chat-status" id="chatStatus">Online ✓</div>
    </div>
    <button class="ib" onclick="clearChat()"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg></button>
  </div>
  <div class="qps" id="qps">
    <button class="qp" onclick="sendQuick(this)">Rangkum catatan</button>
    <button class="qp" onclick="sendQuick(this)">Ide konten</button>
    <button class="qp" onclick="sendQuick(this)">Cek grammar</button>
    <button class="qp" onclick="sendQuick(this)">Buat to-do</button>
    <button class="qp" onclick="sendQuick(this)">Tips coding</button>
    <button class="qp" onclick="sendQuick(this)">Terjemahkan</button>
    <button class="qp" onclick="sendQuick(this)">Motivasi hari ini</button>
  </div>
  <div class="chat-msgs" id="chatMsgs"></div>
  <div class="chat-input-wrap">
    <textarea class="chat-inp" id="chatInp" placeholder="Tanya AI..." rows="1" oninput="autoRes(this)" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg()}"></textarea>
    <button class="chat-send" id="chatSend" onclick="sendMsg()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<!-- SHEETS -->
<div class="ov" id="tdOv" onclick="handleOv(event,'tdOv')">
  <div class="sheet sh-tall">
    <div class="handle"></div>
    <div class="sh-hd">
      <button class="ib" onclick="closeSheet('tdOv')"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      <span class="sh-ttl" style="margin-left:6px">To-Do List</span>
      <button class="ib" style="color:var(--err)" onclick="delTodo()"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg></button>
      <button class="ib" style="color:var(--p);width:auto;padding:0 10px;font-size:13px;font-weight:600;font-family:var(--fb)" onclick="saveTodo()">Simpan</button>
    </div>
    <input type="text" id="tdTitle" placeholder="Nama daftar..." style="width:100%;border:none;background:transparent;outline:none;font-family:var(--fd);font-size:18px;font-weight:500;color:var(--os);padding:7px 14px 5px">
    <div style="display:flex;align-items:center;gap:5px;padding:0 13px 8px;flex-shrink:0">
      <span style="font-size:11px;color:var(--osv)">Warna:</span>
      <div class="cdot sel" style="background:var(--s1);border:1.5px solid var(--outv)" data-tc="" onclick="setTdC(this,'')"></div>
      <div class="cdot" style="background:#FFF9C4" data-tc="cy" onclick="setTdC(this,'cy')"></div>
      <div class="cdot" style="background:#FCE4EC" data-tc="cp" onclick="setTdC(this,'cp')"></div>
      <div class="cdot" style="background:#E3F2FD" data-tc="cb" onclick="setTdC(this,'cb')"></div>
      <div class="cdot" style="background:#E8F5E9" data-tc="cg" onclick="setTdC(this,'cg')"></div>
      <div class="cdot" style="background:#F3E5F5" data-tc="cv" onclick="setTdC(this,'cv')"></div>
    </div>
    <div style="height:1px;background:var(--outv);flex-shrink:0"></div>
    <div class="td-items" id="tdItems"></div>
    <div class="td-add-row">
      <input type="text" class="td-add-inp" id="tdNewInp" placeholder="Tambah item..." onkeydown="if(event.key==='Enter')addTdItem()">
      <button class="td-add-btn" onclick="addTdItem()">+</button>
    </div>
  </div>
</div>
<div class="ov" id="thOv" onclick="handleOv(event,'thOv')"><div class="sheet sh-mid"><div class="handle"></div><div class="sh-hd"><button class="ib" onclick="closeSheet('thOv')"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button><span class="sh-ttl" style="margin-left:6px">Pilih Tema</span></div><div class="th-grid" id="thGrid"></div></div></div>
<div class="ov" id="stOv" onclick="handleOv(event,'stOv')"><div class="sheet sh-mid"><div class="handle"></div><div class="sh-hd"><button class="ib" onclick="closeSheet('stOv')"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button><span class="sh-ttl" style="margin-left:6px">Statistik</span></div><div class="st-grid" id="stGrid"></div></div></div>
<div class="ov" id="wgOv" onclick="handleOv(event,'wgOv')"><div class="sheet sh-mid"><div class="handle"></div><div class="sh-hd"><button class="ib" onclick="closeSheet('wgOv')"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button><span class="sh-ttl" style="margin-left:6px">Widget</span></div><div style="padding:0 12px 5px;font-size:12px;color:var(--osv)">Pilih gaya widget untuk home screen APK</div><div class="wg-grid" id="wgGrid"></div></div></div>
<div class="ov" id="expOv" onclick="handleOv(event,'expOv')"><div class="sheet sh-mid"><div class="handle"></div><div class="sh-hd"><button class="ib" onclick="closeSheet('expOv')"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button><span class="sh-ttl" style="margin-left:6px">Ekspor & Bagikan</span></div><div class="exp-list" id="expList"></div></div></div>

<div class="dlg-ov" id="delDlg">
  <div class="dlg">
    <div class="dlg-t" id="dlgT">Hapus?</div>
    <div class="dlg-b" id="dlgB">Item dipindahkan ke Sampah.</div>
    <div class="dlg-a"><button class="bnt" onclick="closeSheet('delDlg')">Batal</button><button class="bnt err" onclick="confirmDel()">Hapus</button></div>
  </div>
</div>
<div class="snack" id="snack"></div>

</div><!-- #R -->
<script>
'use strict';
// ══ STORAGE ══
function loadNative() {
    try {
        if (window.NativeStorage) {
            // Coba file internal dulu
            let r = window.NativeStorage.loadData();
            if (r && r.length > 2) {
                const d = JSON.parse(r);
                if (d && d.notes && d.notes.length) return d;
            }
            // Fallback ke backup SDCard
            r = window.NativeStorage.loadBackupSD();
            if (r && r.length > 2) {
                const d = JSON.parse(r);
                if (d && d.notes && d.notes.length) return d;
            }
        }
    } catch(e) {}
    return null;
}
const _ns=loadNative();
let notes=_ns?_ns.notes:JSON.parse(localStorage.getItem('nf6_n')||'[]');
let todos=_ns?_ns.todos:JSON.parse(localStorage.getItem('nf6_t')||'[]');
let trash=_ns?_ns.trash:JSON.parse(localStorage.getItem('nf6_x')||'[]');
let chatH=JSON.parse(localStorage.getItem('nf6_c')||'[]');

let curPage='notes',curNote=null,curTodo=null;
let cols=2,activeTag='all',query='';
let pendDel=null;
let edColor='',edPin=false,edLock=false,edFav=false;
let tdColor='',tdItems=[];
let fabOpen=false,snackTmr=null,aiTyping=false;
let curTheme=localStorage.getItem('nf6_theme')||'teal';

const THEMES=[
  {id:'teal',      name:'Teal Ocean',    sub:'Default segar',     colors:['#006A6A','#9DF0EF','#F4FBFB']},
  {id:'violet',    name:'Violet Dream',  sub:'Elegan & modern',   colors:['#6750A4','#EADDFF','#FFFBFE']},
  {id:'rose',      name:'Rose Bloom',    sub:'Hangat & romantis', colors:['#9B1B30','#FFDAD8','#FFFBFF']},
  {id:'ocean',     name:'Ocean Blue',    sub:'Dalam & tenang',    colors:['#0055A5','#D4E4FF','#F5F9FF']},
  {id:'forest',    name:'Forest Green',  sub:'Alami & segar',     colors:['#2D6A4F','#B7E4C7','#F4FAF6']},
  {id:'sunset',    name:'Sunset Orange', sub:'Hangat & energik',  colors:['#BF5700','#FFDBCC','#FFFAF8']},
  {id:'midnight',  name:'Midnight Blue', sub:'Gelap misterius',   colors:['#93CAED','#1A3A52','#080F18']},
  {id:'dark',      name:'Dark Teal',     sub:'Mode gelap teal',   colors:['#9DF0EF','#004F4F','#0E1414']},
  {id:'dark-violet',name:'Dark Violet',  sub:'Mode gelap violet', colors:['#D0BCFF','#4F378B','#1C1B1F']},
  {id:'dark-rose', name:'Dark Rose',     sub:'Mode gelap merah',  colors:['#FFB3B4','#930025','#1C0002']},
];
const TAGS=['teknologi','kerja','ide','personal'];
const AI_API='https://zoyanz-api.vercel.app/ai/copilot';

function save(){
  const d=JSON.stringify({notes,todos,trash});
  localStorage.setItem('nf6_n',JSON.stringify(notes));
  localStorage.setItem('nf6_t',JSON.stringify(todos));
  localStorage.setItem('nf6_x',JSON.stringify(trash));
  try{if(window.NativeStorage){window.NativeStorage.saveData(d);if(notes.length)window.NativeStorage.saveToWidget(notes[0].title||'NoteFlow',strip(notes[0].html).slice(0,120));}}catch(e){}
}
function saveChat(){localStorage.setItem('nf6_c',JSON.stringify(chatH.slice(-80)));}

// ── SEED ──
if(!notes.length){
  notes=[
    {id:1,type:'note',title:'AI & Machine Learning 🤖',html:`<h2>Perkembangan AI 2024</h2><ul><li><strong>GPT-4o</strong> – multimodal real-time</li><li><strong>Gemini Ultra</strong> – melampaui human expert</li><li><strong>Llama 3</strong> – open source lokal</li></ul><blockquote>AI penguat kemampuan manusia.</blockquote>`,color:'cb',tag:'teknologi',pinned:true,locked:false,fav:false,remind:'',date:fmtDate()},
    {id:2,type:'note',title:'Android 15 Highlights 📱',html:`<ol><li><strong>Adaptive Refresh Rate</strong></li><li><strong>Satellite Messaging</strong></li><li><strong>Partial Screen Share</strong></li><li><strong>Material You v3</strong></li></ol><p>Rilis: <mark>Q3 2024</mark></p>`,color:'cg',tag:'teknologi',pinned:false,locked:false,fav:true,remind:'',date:fmtDate()},
    {id:3,type:'note',title:'Git Workflow Tips 🌿',html:`<ul><li><code>git rebase -i HEAD~3</code> — squash commits</li><li><code>git bisect</code> — cari bug</li><li><code>git stash</code> — simpan perubahan sementara</li></ul>`,color:'co',tag:'teknologi',pinned:false,locked:false,fav:false,remind:'',date:fmtDate()},
    {id:4,type:'note',title:'Meeting Sprint Q1 💼',html:`<ul><li>✅ Login SSO – Reza</li><li>✅ Redesign dashboard</li><li>🔄 Optimasi query DB</li><li>❌ Dark mode – ditunda Q2</li></ul><p><strong>Demo:</strong> Jumat jam 10</p>`,color:'cp',tag:'kerja',pinned:false,locked:false,fav:false,remind:'',date:fmtDate()},
  ];
  todos=[
    {id:10,type:'todo',title:'🚀 Sprint Dev',color:'cb',items:[{id:101,text:'Setup Turborepo',done:true},{id:102,text:'JWT auth',done:false},{id:103,text:'Deploy Vercel',done:false},{id:104,text:'Unit tests 80%',done:false}],date:fmtDate()},
    {id:11,type:'todo',title:'📚 Belajar',color:'cv',items:[{id:111,text:'Next.js 14 App Router',done:true},{id:112,text:'TypeScript generics',done:true},{id:113,text:'Rust dasar',done:false}],date:fmtDate()},
  ];
  save();
}
applyTheme(curTheme);

// ══ UTILS ══
function fmtDate(){return new Date().toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'})}
function fmtTime(){return new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})}
function uid(){return Date.now()^(Math.random()*0xFFFF|0)}
function strip(h){const d=document.createElement('div');d.innerHTML=h||'';return d.textContent||''}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}

// ══ VIEW NAV ══
function gotoView(id){
  const all=['vL','vE','vC'];
  const cur=all.find(v=>{const el=document.getElementById(v);return !el.classList.contains('gone')&&!el.classList.contains('sright')&&!el.classList.contains('sleft');});
  if(cur===id)return;
  const going_forward=(all.indexOf(id)>all.indexOf(cur||'vL'));
  if(cur){
    const el=document.getElementById(cur);
    el.classList.add(going_forward?'sleft':'sright');
    setTimeout(()=>el.classList.add('gone'),320);
  }
  const next=document.getElementById(id);
  next.classList.remove('gone');
  next.classList.add(going_forward?'sright':'sleft');
  requestAnimationFrame(()=>requestAnimationFrame(()=>next.classList.remove('sright','sleft')));
}

// ══ RENDER ══
let _rp=false;
function render(){if(_rp)return;_rp=true;requestAnimationFrame(_doRender);}
function _doRender(){
  _rp=false;
  const g=document.getElementById('grid');
  g.style.setProperty('--cols',cols);
  let items=[];
  if(curPage==='trash'){
    items=trash;
    const bar=document.getElementById('trashBar');
    bar.classList.toggle('show',trash.length>0);
    document.getElementById('trashInfo').textContent=trash.length+' item di sampah';
  } else if(curPage==='fav'){
    // Favorit view — render di luar grid
    renderFavView();return;
  } else {
    document.getElementById('trashBar').classList.remove('show');
    if(curPage==='pinned')items=[...notes.filter(n=>n.pinned),...todos];
    else if(curPage==='todo')items=todos.filter(t=>!query||t.title.toLowerCase().includes(query));
    else{
      let n2=[...notes],t2=[...todos];
      if(query){n2=n2.filter(n=>(n.title+strip(n.html)).toLowerCase().includes(query));t2=t2.filter(t=>t.title.toLowerCase().includes(query));}
      if(activeTag==='todo')items=t2;
      else if(activeTag!=='all')items=n2.filter(n=>n.tag===activeTag);
      else items=[...n2,...t2];
    }
  }

  if(!items.length){
    const ico=curPage==='trash'?'🗑️':curPage==='todo'?'☑️':'📝';
    g.innerHTML=`<div class="empty"><div class="empty-ic">${ico}</div><div class="empty-tx">Belum ada item.<br>Tap + untuk mulai!</div></div>`;
    return;
  }

  let html='';
  if(curPage==='notes'&&activeTag!=='todo'){
    const pinned=items.filter(i=>i.type==='note'&&i.pinned);
    const rest=items.filter(i=>!(i.type==='note'&&i.pinned));
    if(pinned.length){html+=`<div class="slbl">📌 Disematkan</div>`;pinned.forEach((n,i)=>html+=mkCard(n,i));}
    if(rest.length){if(pinned.length)html+=`<div class="slbl">Lainnya</div>`;rest.forEach((n,i)=>html+=mkCard(n,i+pinned.length));}
  } else items.forEach((n,i)=>html+=mkCard(n,i));

  g.innerHTML=html;
  g.querySelectorAll('[data-id]').forEach(el=>{
    const id=+el.dataset.id,type=el.dataset.type;
    if(curPage!=='trash'){
      el.addEventListener('click',()=>{
        if(type==='todo'){const t=todos.find(x=>x.id===id);if(t)openTdEd(t);}
        else{const n=notes.find(x=>x.id===id);if(n)openEditor(n);}
      },{passive:true});
    }
  });
  g.querySelectorAll('[data-cb]').forEach(cb=>{
    cb.addEventListener('click',e=>{e.stopPropagation();qToggle(+cb.dataset.cb,+cb.dataset.item,cb);},{passive:true});
  });
}

function mkCard(item,idx){
  const d=Math.min(idx*20,240);
  if(item.type==='todo'){
    const done=item.items.filter(i=>i.done).length,total=item.items.length,pct=total?Math.round(done/total*100):0;
    return `<div class="tc ${item.color||''}" data-id="${item.id}" data-type="todo" style="animation-delay:${d}ms">
      <div class="tc-hd"><span style="font-size:14px">☑️</span><span class="tc-ttl">${esc(item.title)}</span><span class="tc-pct">${done}/${total}</span></div>
      <div class="tc-prog"><div class="tc-bar" style="width:${pct}%"></div></div>
      ${item.items.slice(0,3).map(it=>`<div class="ti"><div class="ti-cb${it.done?' done':''}" data-cb="${item.id}" data-item="${it.id}"></div><span class="ti-txt${it.done?' done':''}">${esc(it.text)}</span></div>`).join('')}
      ${total>3?`<div style="font-size:10px;color:var(--osv);padding:3px 0">+${total-3} lagi</div>`:''}
      <div style="display:flex;justify-content:space-between;margin-top:6px"><span class="nc-date">${item.date}</span><span style="font-size:10px;color:var(--p);font-weight:600">${pct}%</span></div>
    </div>`;
  }
  const body=item.locked?'🔒 Dikunci':strip(item.html);
  const badges=(item.tag?`<span class="btag">${item.tag}</span>`:'')+(item.pinned?'<span style="font-size:11px">📌</span>':'')+(item.fav?'<span style="font-size:11px">⭐</span>':'')+(item.remind?'<span style="font-size:11px">🔔</span>':'');
  return `<div class="nc ${item.color||''}" data-id="${item.id}" data-type="note" style="animation-delay:${d}ms">
    ${item.locked?'<span style="position:absolute;top:8px;right:8px;font-size:11px">🔒</span>':''}
    ${item.title?`<div class="nc-title">${esc(item.title)}</div>`:''}
    <div class="nc-body">${esc(body)}</div>
    ${badges?`<div class="nc-badges">${badges}</div>`:''}
    <div class="nc-date">${item.date}</div>
  </div>`;
}

function qToggle(todoId,itemId,el){
  const todo=todos.find(t=>t.id===todoId);if(!todo)return;
  const item=todo.items.find(i=>i.id===itemId);if(!item)return;
  item.done=!item.done;
  el.classList.toggle('done');el.nextElementSibling?.classList.toggle('done');
  const card=el.closest('.tc');
  if(card){
    const done=todo.items.filter(i=>i.done).length,total=todo.items.length,pct=total?Math.round(done/total*100):0;
    const bar=card.querySelector('.tc-bar');if(bar)bar.style.width=pct+'%';
    const pc=card.querySelector('.tc-pct');if(pc)pc.textContent=`${done}/${total}`;
    card.querySelectorAll('span[style*="color:var(--p)"]').forEach(x=>{if(x.textContent.includes('%'))x.textContent=pct+'%';});
  }
  save();
}

// ══ FAVORIT VIEW ══
function renderFavView(){
  const g=document.getElementById('grid');
  g.style.setProperty('--cols',1);
  const favNotes=notes.filter(n=>n.fav);
  const pinnedNotes=notes.filter(n=>n.pinned);
  if(!favNotes.length&&!pinnedNotes.length){
    g.innerHTML=`<div class="empty"><div class="empty-ic">⭐</div><div class="empty-tx">Belum ada favorit.<br>Bintangi catatan saat mengedit!</div></div>`;
    return;
  }
  let html='';
  if(favNotes.length){html+=`<div class="slbl">⭐ Favorit</div>`;favNotes.forEach((n,i)=>html+=mkCard(n,i));}
  if(pinnedNotes.length){html+=`<div class="slbl">📌 Disematkan</div>`;pinnedNotes.forEach((n,i)=>html+=mkCard(n,i+favNotes.length));}
  g.innerHTML=html;
  g.querySelectorAll('[data-id]').forEach(el=>{
    const id=+el.dataset.id;
    el.addEventListener('click',()=>{const n=notes.find(x=>x.id===id);if(n)openEditor(n);},{passive:true});
  });
}

// ══ EDITOR ══
function openEditor(note=null){
  curNote=note;
  document.getElementById('edTitle').value=note?note.title:'';
  document.getElementById('edBody').innerHTML=note?note.html||'':'';
  edColor=note?note.color||'':'';edPin=note?!!note.pinned:false;edLock=note?!!note.locked:false;edFav=note?!!note.fav:false;
  updatePinBtn();updateLockBtn();updateStarBtn();updateColorDots();updateWC();
  renderMeta(note?note.tag:'teknologi',note?note.remind||'':'');
  gotoView('vE');
  setTimeout(()=>document.getElementById('edBody').focus(),340);
}
function closeEditor(){gotoView('vL');curNote=null;}
function saveNote(){
  const title=document.getElementById('edTitle').value.trim();
  const html=document.getElementById('edBody').innerHTML.trim();
  if(!title&&(!html||html==='<br>')){closeEditor();return;}
  const tagEl=document.querySelector('#edMeta .mc.act[data-tag]');
  const tag=tagEl?tagEl.dataset.tag:'teknologi';
  const remEl=document.getElementById('edRemInp');
  const remind=remEl?remEl.value:'';
  const wc=strip(html).trim().split(/\s+/).filter(Boolean).length;
  if(curNote){const i=notes.findIndex(n=>n.id===curNote.id);if(i!==-1)notes[i]={...notes[i],title,html,color:edColor,pinned:edPin,locked:edLock,fav:edFav,remind,tag,date:fmtDate(),wc};}
  else notes.unshift({id:uid(),type:'note',title,html,color:edColor,tag,pinned:edPin,locked:edLock,fav:edFav,remind,date:fmtDate(),wc});
  save();render();closeEditor();snack('Disimpan ✓');
}
function delNote(){if(!curNote){closeEditor();return;}pendDel={id:curNote.id,type:'note'};showDlg('Hapus catatan?','Dipindahkan ke Sampah.');}
function togglePin(){edPin=!edPin;updatePinBtn();}
function updatePinBtn(){document.getElementById('pinBtn').classList.toggle('act',edPin);}
function toggleLock(){edLock=!edLock;updateLockBtn();}
function updateLockBtn(){document.getElementById('lockBtn').classList.toggle('act',edLock);document.getElementById('lockIco').innerHTML=edLock?'<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><line x1="12" y1="15" x2="12" y2="17"/>':'<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>';}
function toggleFav(){edFav=!edFav;updateStarBtn();}
function updateStarBtn(){const btn=document.getElementById('starBtn');const ico=document.getElementById('starIco');btn.classList.toggle('act',edFav);ico.style.fill=edFav?'currentColor':'none';}
function setColor(el,c){edColor=c;updateColorDots();}
function updateColorDots(){document.querySelectorAll('.cdot[data-c]').forEach(d=>d.classList.toggle('sel',d.dataset.c===edColor));}
function updateWC(){const w=strip(document.getElementById('edBody').innerHTML).trim().split(/\s+/).filter(Boolean).length;document.getElementById('edWC').textContent=w+' kata';}
function autoRes(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
function renderMeta(selTag,selRemind){
  let h=TAGS.map(t=>`<button class="mc${selTag===t?' act':''}" data-tag="${t}" onclick="selMT(this)">${t}</button>`).join('');
  h+=`<div class="ms"></div><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--osv)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`;
  h+=`<input type="datetime-local" id="edRemInp" value="${selRemind||''}" style="border:none;background:var(--s2);border-radius:var(--r8);padding:4px 8px;font-family:var(--fb);font-size:11px;color:var(--os);outline:none;flex-shrink:0;min-width:0;max-width:160px">`;
  document.getElementById('edMeta').innerHTML=h;
}
function selMT(el){document.querySelectorAll('#edMeta .mc[data-tag]').forEach(c=>c.classList.remove('act'));el.classList.add('act');}
function xCmd(cmd,val){document.getElementById('edBody').focus();document.execCommand(cmd,false,val||null);updFmt();}
function updFmt(){[['fB','bold'],['fI','italic'],['fU','underline'],['fS','strikeThrough']].forEach(([id,cmd])=>{const el=document.getElementById(id);if(el)el.classList.toggle('on',document.queryCommandState(cmd));});}
function insCode(){document.getElementById('edBody').focus();document.execCommand('insertHTML',false,'<code>kode</code>');}
function insLink(){const u=prompt('URL:','https://');if(u)document.execCommand('createLink',false,u);}
function insTable(){document.getElementById('edBody').focus();document.execCommand('insertHTML',false,'<table><tr><th>Kolom 1</th><th>Kolom 2</th></tr><tr><td>Data</td><td>Data</td></tr></table><p></p>');}
function toggleFind(){const b=document.getElementById('findBar');const s=!b.classList.contains('show');b.classList.toggle('show',s);document.getElementById('findBtn').classList.toggle('act',s);if(s)setTimeout(()=>document.getElementById('findInp').focus(),100);}
function doFind(){const q=document.getElementById('findInp').value;if(!q){document.getElementById('findInfo').textContent='0';return;}const c=(strip(document.getElementById('edBody').innerHTML).match(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi'))||[]).length;document.getElementById('findInfo').textContent=c;}
function doReplace(){const f=document.getElementById('findInp').value,r=document.getElementById('replInp').value;if(!f)return;const b=document.getElementById('edBody');b.innerHTML=b.innerHTML.split(f).join(r);snack(`"${f}" → "${r}"`);doFind();}
function shareNote(){const t=document.getElementById('edTitle').value,b=strip(document.getElementById('edBody').innerHTML);if(navigator.share)navigator.share({title:t,text:b});else{navigator.clipboard?.writeText(t+'\n\n'+b);snack('Disalin!');}}

// ══ CHAT AI ══
function showChat(){
  gotoView('vC');
  renderMsgs();
  if(!chatH.length)addAI('Halo! Gue NoteFlow AI 🤖\nBisa bantu kamu nulis, rangkum catatan, atau jawab pertanyaan. Mau ngobrol apa?');
  setTimeout(()=>document.getElementById('chatInp').focus(),360);
}
function closeChat(){gotoView('vL');}
function clearChat(){chatH=[];saveChat();renderMsgs();addAI('Chat bersih ✨ Ada yang mau ditanya?');}

function renderMsgs(){
  const box=document.getElementById('chatMsgs');
  box.innerHTML=chatH.map(m=>`
    <div class="msg ${m.role}">
      ${m.role==='ai'?'<div class="msg-av">🤖</div>':''}
      <div class="msg-wrap">
        <div class="msg-bubble">${m.role==='ai'?fmtAI(m.text):esc(m.text)}</div>
        <div class="msg-time">${m.time||''}</div>
        ${m.role==='ai'?`<button class="ai-save-btn" onclick="saveAInote(this)">📝 Simpan jadi catatan</button>`:''}
      </div>
      ${m.role==='user'?'<div class="msg-av uav">U</div>':''}
    </div>`).join('');
  // Attach save events
  box.querySelectorAll('.ai-save-btn').forEach((btn,i)=>{
    const msgs=chatH.filter(m=>m.role==='ai');
    if(msgs[i])btn.onclick=()=>saveAInote2(msgs[i].text);
  });
  box.scrollTop=999999;
}
function fmtAI(t){return esc(t).replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\*(.*?)\*/g,'<em>$1</em>').replace(/`(.*?)`/g,'<code style="background:var(--s2);padding:1px 4px;border-radius:3px">$1</code>').replace(/\n/g,'<br>');}
function addAI(text){chatH.push({role:'ai',text,time:fmtTime()});saveChat();renderMsgs();}

async function sendMsg(){
  const inp=document.getElementById('chatInp');
  const msg=inp.value.trim();if(!msg||aiTyping)return;
  inp.value='';autoRes(inp);
  chatH.push({role:'user',text:msg,time:fmtTime()});saveChat();renderMsgs();
  aiTyping=true;
  document.getElementById('chatSend').disabled=true;
  document.getElementById('chatStatus').textContent='Mengetik...';
  const tyEl=document.createElement('div');
  tyEl.className='msg ai';tyEl.id='ty';
  tyEl.innerHTML='<div class="msg-av">🤖</div><div class="typing"><span></span><span></span><span></span></div>';
  document.getElementById('chatMsgs').appendChild(tyEl);
  document.getElementById('chatMsgs').scrollTop=999999;
  const noteCtx=notes.slice(0,2).map(n=>`"${n.title}": ${strip(n.html).slice(0,80)}`).join('\n');
  const ctx=noteCtx?`Konteks catatan:\n${noteCtx}\n\nPertanyaan: ${msg}`:msg;
  try{
    const res=await fetch(`${AI_API}?message=${encodeURIComponent(ctx)}&model=default`);
    const data=await res.json();
    const reply=data?.result?.text||data?.result||'Maaf, tidak ada respons.';
    document.getElementById('ty')?.remove();
    addAI(typeof reply==='string'?reply:JSON.stringify(reply));
  }catch(e){
    document.getElementById('ty')?.remove();
    addAI('Koneksi bermasalah 😅 Coba lagi atau cek internet kamu.');
  }finally{
    aiTyping=false;
    document.getElementById('chatSend').disabled=false;
    document.getElementById('chatStatus').textContent='Online ✓';
  }
}
function sendQuick(btn){document.getElementById('chatInp').value=btn.textContent;sendMsg();}
function saveAInote2(text){
  notes.unshift({id:uid(),type:'note',title:'AI – '+fmtDate(),html:'<p>'+text.replace(/\n/g,'</p><p>')+'</p>',color:'cb',tag:'ide',pinned:false,locked:false,fav:false,remind:'',date:fmtDate(),wc:text.split(/\s+/).length});
  save();render();snack('Disimpan sebagai catatan ✓');
}

// ══ TODO ══
function openTdEd(todo=null){curTodo=todo;document.getElementById('tdTitle').value=todo?todo.title:'';tdColor=todo?todo.color||'':'';tdItems=todo?JSON.parse(JSON.stringify(todo.items)):[];updateTdCD();renderTdItems();document.getElementById('tdOv').classList.add('open');setTimeout(()=>document.getElementById('tdTitle').focus(),360);}
function saveTodo(){const title=document.getElementById('tdTitle').value.trim()||'To-Do';if(curTodo){const i=todos.findIndex(t=>t.id===curTodo.id);if(i!==-1)todos[i]={...todos[i],title,color:tdColor,items:tdItems,date:fmtDate()};}else todos.unshift({id:uid(),type:'todo',title,color:tdColor,items:tdItems,date:fmtDate()});save();render();closeSheet('tdOv');snack('To-Do disimpan ✓');curTodo=null;}
function delTodo(){if(!curTodo){closeSheet('tdOv');return;}pendDel={id:curTodo.id,type:'todo'};showDlg('Hapus to-do?','Dipindahkan ke Sampah.');}
function addTdItem(){const i=document.getElementById('tdNewInp');const t=i.value.trim();if(!t)return;tdItems.push({id:uid(),text:t,done:false});i.value='';renderTdItems();document.getElementById('tdItems').scrollTop=999999;}
function renderTdItems(){document.getElementById('tdItems').innerHTML=tdItems.map((item,i)=>`<div class="td-item"><span class="td-drag">⠿</span><div class="ti-cb${item.done?' done':''}" onclick="tdt(${i},this)"></div><input class="td-inp" value="${esc(item.text)}" oninput="tdItems[${i}].text=this.value" placeholder="Item..."><button class="td-del" onclick="tdr(${i})">✕</button></div>`).join('');}
function tdt(i,el){tdItems[i].done=!tdItems[i].done;el.classList.toggle('done');el.nextElementSibling?.classList.toggle('done');}
function tdr(i){tdItems.splice(i,1);renderTdItems();}
function setTdC(el,c){tdColor=c;updateTdCD();}
function updateTdCD(){document.querySelectorAll('.cdot[data-tc]').forEach(d=>d.classList.toggle('sel',d.dataset.tc===tdColor));}

// ══ DELETE ══
function showDlg(t,b){document.getElementById('dlgT').textContent=t;document.getElementById('dlgB').textContent=b;document.getElementById('delDlg').classList.add('open');}
function confirmDel(){
  if(!pendDel){closeSheet('delDlg');return;}
  const{id,type}=pendDel;
  if(type==='note'){const i=notes.findIndex(n=>n.id===id);if(i!==-1){trash.unshift({...notes[i],deletedAt:Date.now()});notes.splice(i,1);}}
  else if(type==='todo'){const i=todos.findIndex(t=>t.id===id);if(i!==-1){trash.unshift({...todos[i],deletedAt:Date.now()});todos.splice(i,1);}}
  else if(type==='empty'){trash=[];}
  save();render();closeSheet('delDlg');
  if(type==='note')closeEditor();else if(type==='todo')closeSheet('tdOv');
  snack(type==='empty'?'Sampah dikosongkan':'Dipindahkan ke Sampah');
  pendDel=null;curNote=null;curTodo=null;
}
function emptyTrash(){if(!trash.length)return;pendDel={type:'empty'};showDlg('Kosongkan Sampah?',trash.length+' item dihapus permanen!');}

// ══ SNACK ══
function snack(msg){clearTimeout(snackTmr);const el=document.getElementById('snack');el.textContent=msg;el.classList.add('show');snackTmr=setTimeout(()=>el.classList.remove('show'),2500);}

// ══ SEARCH ══
function doSearch(){query=document.getElementById('srchInp').value.toLowerCase().trim();document.getElementById('srchX').style.display=query?'flex':'none';render();}
function clearSearch(){document.getElementById('srchInp').value='';query='';document.getElementById('srchX').style.display='none';render();}
function filterTag(tag,el){activeTag=tag;document.querySelectorAll('#chips .chip').forEach(c=>c.classList.remove('act'));el.classList.add('act');render();}

// ══ NAV ══
function navTo(page,el){
  curPage=page;
  document.querySelectorAll('.ni').forEach(n=>n.classList.remove('act'));
  el.classList.add('act');
  document.getElementById('pgTitle').textContent={notes:'Catatan',todo:'To-Do',fav:'Favorit',trash:'Sampah'}[page]||'Catatan';
  document.getElementById('chips').style.display=page==='notes'?'flex':'none';
  document.getElementById('fabWrap').style.display=page==='trash'?'none':'';
  render();
}
function toggleCols(){
  cols=cols>=2?1:2;
  document.getElementById('viewIco').innerHTML=cols===1?'<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>':'<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>';
  render();
}

// ══ FAB ══
function toggleFab(){fabOpen=!fabOpen;document.getElementById('fabTd').classList.toggle('vis',fabOpen);document.getElementById('fabNt').classList.toggle('vis',fabOpen);document.getElementById('fabIco').innerHTML=fabOpen?'<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>':'<path d="M12 5v14M5 12h14"/>';}
function closeFab(){if(!fabOpen)return;fabOpen=false;document.getElementById('fabTd').classList.remove('vis');document.getElementById('fabNt').classList.remove('vis');document.getElementById('fabIco').innerHTML='<path d="M12 5v14M5 12h14"/>';}

// ══ THEME ══
function applyTheme(id){curTheme=id;document.documentElement.setAttribute('data-t',id==='teal'?'':id);document.getElementById('R').style.background='var(--bg)';localStorage.setItem('nf6_theme',id);}
function openTheme(){
  document.getElementById('thGrid').innerHTML=THEMES.map(t=>`
    <div class="th-card${curTheme===t.id?' sel':''}" style="background:${t.colors[2]}" onclick="applyTheme('${t.id}');document.querySelectorAll('.th-card').forEach(c=>c.classList.remove('sel'));this.classList.add('sel');snack('Tema ${t.name} ✓')">
      <div class="sw-row">${t.colors.map(c=>`<div class="sw" style="background:${c}"></div>`).join('')}</div>
      <div class="th-nm" style="color:${t.colors[0]}">${t.name}</div>
      <div class="th-sb">${t.sub}</div>
    </div>`).join('');
  document.getElementById('thOv').classList.add('open');
}

// ══ STATS ══
function openStats(){
  const tTd=todos.reduce((a,t)=>a+t.items.length,0),dTd=todos.reduce((a,t)=>a+t.items.filter(i=>i.done).length,0);
  document.getElementById('stGrid').innerHTML=[
    {n:notes.length,l:'Catatan',ic:'📝'},{n:todos.length,l:'To-Do',ic:'☑️'},
    {n:notes.filter(n=>n.pinned).length,l:'Disematkan',ic:'📌'},{n:notes.filter(n=>n.fav).length,l:'Favorit',ic:'⭐'},
    {n:notes.filter(n=>n.locked).length,l:'Dikunci',ic:'🔒'},{n:tTd,l:'Total Tugas',ic:'📋'},
    {n:dTd,l:'Selesai',ic:'✅'},{n:trash.length,l:'Sampah',ic:'🗑️'},
    {n:notes.reduce((a,n)=>a+(n.wc||0),0),l:'Total Kata',ic:'✍️'},{n:notes.filter(n=>n.remind).length,l:'Pengingat',ic:'🔔'},
  ].map(d=>`<div class="st-card"><div style="font-size:18px;margin-bottom:3px">${d.ic}</div><div class="st-num">${d.n}</div><div class="st-lbl">${d.l}</div></div>`).join('');
  document.getElementById('stOv').classList.add('open');
}

// ══ WIDGET ══
function openWidget(){
  const n=notes[0]||{title:'NoteFlow',html:'<p>Belum ada.</p>'};const td=todos[0];
  document.getElementById('wgGrid').innerHTML=[
    {lbl:'Mini Note',w:'',body:`<div class="wg-nt">${esc(n.title)}</div><div class="wg-nb">${esc(strip(n.html))}</div>`},
    {lbl:'To-Do',w:'',body:td?`<div class="wg-nt">${esc(td.title)}</div>${td.items.slice(0,3).map(i=>`<div style="font-size:10px;color:color-mix(in srgb,var(--opc) 70%,transparent);padding:1px 0">${i.done?'✓':'○'} ${esc(i.text)}</div>`).join('')}`:'<div class="wg-nb">Belum ada to-do</div>'},
    {lbl:'Banner',w:'wide',body:`<div class="wg-nt">${esc(n.title)}</div><div class="wg-nb">${esc(strip(n.html).slice(0,80))}</div><div style="margin-top:7px;display:flex;gap:5px"><span style="background:var(--p);color:var(--op);border-radius:20px;padding:3px 10px;font-size:10px;font-weight:600">+ Baru</span></div>`},
    {lbl:'Daftar',w:'wide',body:notes.slice(0,3).map(no=>`<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px"><div style="width:4px;height:4px;border-radius:50%;background:var(--p)"></div><div style="font-size:11px;font-weight:500;color:var(--opc);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(no.title)}</div></div>`).join('')},
  ].map(s=>`<div class="wg-card${s.w?' '+s.w:''}" onclick="this.closest('.wg-grid').querySelectorAll('.wg-card').forEach(c=>c.classList.remove('sel'));this.classList.add('sel');setTimeout(()=>{closeSheet('wgOv');snack('Widget dipilih ✓');},240)"><div class="wg-lbl">${s.lbl}</div>${s.body}</div>`).join('');
  document.getElementById('wgOv').classList.add('open');
}

// ══ EXPORT ══
function openExport(){
  const items=[
    {ic:'📋',nm:'Salin Semua',sb:'Salin ke clipboard',fn(){navigator.clipboard?.writeText(notes.map(n=>n.title+'\n'+strip(n.html)).join('\n\n---\n\n'));snack('Disalin!');closeSheet('expOv');}},
    {ic:'💾',nm:'Backup JSON',sb:'Simpan semua data lokal',fn(){const a=document.createElement('a');a.href='data:application/json,'+encodeURIComponent(JSON.stringify({notes,todos},null,2));a.download='noteflow-backup.json';a.click();snack('Backup diunduh!');closeSheet('expOv');}},
    {ic:'📄',nm:'Ekspor HTML',sb:'Semua catatan sebagai webpage',fn(){const body=notes.map(n=>`<h2>${n.title}</h2>${n.html}<hr>`).join('');const h=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>NoteFlow Export</title><style>body{font-family:sans-serif;max-width:800px;margin:40px auto;padding:0 20px;line-height:1.6}h2{color:#006A6A}</style></head><body>${body}</body></html>`;const a=document.createElement('a');a.href='data:text/html,'+encodeURIComponent(h);a.download='noteflow.html';a.click();snack('Diekspor!');closeSheet('expOv');}},
    {ic:'🗑️',nm:'Kosongkan Sampah',sb:trash.length+' item di sampah',fn(){closeSheet('expOv');emptyTrash();}},
  ];
  const list=document.getElementById('expList');list.innerHTML='';
  items.forEach(item=>{const d=document.createElement('div');d.className='exp-item';d.innerHTML=`<div class="exp-ic">${item.ic}</div><div><div class="exp-nm">${item.nm}</div><div class="exp-sb">${item.sb}</div></div>`;d.onclick=item.fn;list.appendChild(d);});
  document.getElementById('expOv').classList.add('open');
}

// ══ OVERLAYS ══
function handleOv(e,id){if(e.target.id===id)closeSheet(id);}
function closeSheet(id){document.getElementById(id).classList.remove('open');if(id==='tdOv')curTodo=null;}

// Swipe sheets
['tdOv','thOv','stOv','wgOv','expOv'].forEach(id=>{
  const ov=document.getElementById(id);const sh=ov?.querySelector('.sheet');if(!sh)return;
  let sy=0,drag=false,ss=0;
  sh.addEventListener('touchstart',e=>{sy=e.touches[0].clientY;drag=false;ss=sh.scrollTop;},{passive:true});
  sh.addEventListener('touchmove',e=>{const dy=e.touches[0].clientY-sy;if(dy>8&&ss<=0){drag=true;sh.style.cssText=`transform:translateY(${dy}px);transition:none`;}},{passive:true});
  sh.addEventListener('touchend',e=>{sh.style.cssText='';if(drag&&(e.changedTouches[0].clientY-sy)>100)closeSheet(id);drag=false;},{passive:true});
});

// Scroll top bar border
document.getElementById('cont').addEventListener('scroll',function(){document.getElementById('tbar').classList.toggle('sc',this.scrollTop>2);},{passive:true});
document.getElementById('cont').addEventListener('click',closeFab,{passive:true});

// Keyboard
document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='s'){e.preventDefault();if(!document.getElementById('vE').classList.contains('gone'))saveNote();}
  if(e.key==='Escape'){
    if(!document.getElementById('vE').classList.contains('gone')){closeEditor();return;}
    if(!document.getElementById('vC').classList.contains('gone')){closeChat();return;}
    ['tdOv','thOv','stOv','wgOv','expOv','delDlg'].forEach(closeSheet);closeFab();
  }
});

render();
</script>
</body>
</html>
